							"//Assign variables\r",
							"  //Get the response body as json\r",
							"   let response = pm.response.json();\r",
							"   let responseValues = response.value;\r",
							"\r",
							"//Tests\r",
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"pm.test(\"Only 2 properties are returned for the vessels\", function () {\r",
							"    const moreThan2Params = responseValues.filter(item => Object.keys(item).length !== 2);\r",
							"    pm.expect((moreThan2Params.length === 0), \"There are more or less than two properties returned for the vessel\").to.be.true;\r",
							"});\r",
							"\r",
							"pm.test(\"Body contains Name and IMO keys\", function () {\r",
							"    let vesselProperties = JSON.parse(pm.environment.get(\"vesselProperties\"));\r",
							"    let isCorrectProperties = responseValues.every(item => {\r",
							"        for(let i = 0; i < Object.keys(item).length; i++) {\r",
							"            // console.log(Object.keys(item).length)\r",
							"            // console.log(i)\r",
							"            // console.log(Object.keys(item)[i]);\r",
							"            // console.log(vesselProperties[i]);\r",
							"            if (Object.keys(item)[i] !== vesselProperties[i]){\r",
							"                console.log(\"The elements in both arrays are not equal\");\r",
							"                return false;\r",
							"            }\r",
							"        }\r",
							"        return true;\r",
							"    })    \r",
							"    console.log(isCorrectProperties)\r",
							"    pm.expect(isCorrectProperties, \"Name or IMO property is missing\").to.be.true;\r",
							"});\r",
							"\r",
							"pm.test(\"Only vessels with API node are returned\", function () {\r",
							"        pm.expect(equalArray(actualVesselsArr, vesselsWithApiNodeArr),\"Not all listed vessels contain API node\").to.be.true;\r",
							"\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
