				{
					"name": "625823. GET /api/metadata/types",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"id": "1e21ca74-9e36-4a71-9093-aa3abf8e70e0",
								"exec": [
									"pm.environment.set(\"expectedTypesArray\", JSON.stringify([\r",
									"    { name: \"NoType\", value: 0 },\r",
									"    { name: \"Bool\", value: 1 },\r",
									"    { name: \"Sbyte\", value: 2 },\r",
									"    { name: \"Byte\", value: 3 },\r",
									"    { name: \"Int16\", value: 4 },\r",
									"    { name: \"Uint16\", value: 5 },\r",
									"    { name: \"Int32\", value: 6 },\r",
									"    { name: \"Uint32\", value: 7 },\r",
									"    { name: \"Int64\", value: 8 },\r",
									"    { name: \"Uint64\", value: 9 },\r",
									"    { name: \"Float\", value: 10 },\r",
									"    { name: \"Double\", value: 11 },\r",
									"    { name: \"DateTime\", value: 15 },\r",
									"    { name: \"Text\", value: 20 }\r",
									"]));\r",
									"\r",
									"// Get the Postman variable (assumed to be a stringified JSON array)\r",
									"expectedTypesJSON = JSON.parse(pm.environment.get(\"expectedTypesArray\"));\r",
									"console.log(expectedTypesJSON)"
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"id": "96feabf6-18fb-485a-8f2f-475bf257748c",
								"exec": [
									"// Parse the response JSON\r",
									"let responseJSON = pm.response.json();\r",
									"\r",
									"// Function to deep compare two objects (including sorting keys)\r",
									"function deepCompareObjects(obj1, obj2) {\r",
									"    // If both are objects, continue with deep comparison\r",
									"    if (typeof obj1 === 'object' && obj1 !== null && typeof obj2 === 'object' && obj2 !== null) {\r",
									"        // Get the keys of both objects and sort them to ensure order doesn't matter\r",
									"        const keys1 = Object.keys(obj1).sort();\r",
									"        const keys2 = Object.keys(obj2).sort();\r",
									"\r",
									"        // If the sorted keys are different, the objects are not equal\r",
									"        if (keys1.length !== keys2.length) return false;\r",
									"\r",
									"        // Compare each key in both objects\r",
									"        for (let i = 0; i < keys1.length; i++) {\r",
									"            const key = keys1[i];\r",
									"            if (!deepCompareObjects(obj1[key], obj2[key])) {\r",
									"                return false;\r",
									"            }\r",
									"        }\r",
									"        return true;\r",
									"    } else {\r",
									"        // For primitive values, directly compare them\r",
									"        return obj1 === obj2;\r",
									"    }\r",
									"}\r",
									"\r",
									"// Perform deep comparison between responseArray and expectedArray\r",
									"pm.test(\"Response matches expected array\", function () {\r",
									"    const areEqual = deepCompareObjects(responseJSON, expectedTypesJSON);\r",
									"    pm.expect(areEqual).to.be.true;  // Assert that they are deeply equal\r",
									"});\r",
									"\r",
									"\r",
									"\r",
									"\r",
									"\r",
									"\r",
									"\r",
									"\r",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
