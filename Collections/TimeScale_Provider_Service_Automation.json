		{
			"listen": "prerequest",
			"script": {
				"id": "0e8a5153-dda1-4242-8f7a-f94cd42d3dab",
				"type": "text/javascript",
				"packages": {},
				"exec": [
					"const clientId = pm.environment.get(\"Client_ID\");\r",
					"const clientSecret = pm.environment.get(\"Client_Secret\");\r",
					"const authUrl = pm.environment.get(\"auth_url\");\r",
					"const scope = pm.environment.get(\"scope\"); // optional\r",
					"\r",
					"const encodedCreds = Buffer.from(`${clientId}:${clientSecret}`).toString('base64');\r",
					"\r",
					"const bodyParams = [\r",
					"  { key: 'grant_type', value: 'client_credentials' }\r",
					"];\r",
					"if (scope) {\r",
					"  bodyParams.push({ key: 'scope', value: scope });\r",
					"}\r",
					"\r",
					"pm.sendRequest({\r",
					"  url: authUrl,\r",
					"  method: 'POST',\r",
					"  header: [\r",
					"    { key: 'Authorization', value: `Basic ${encodedCreds}` },\r",
					"    { key: 'Content-Type', value: 'application/x-www-form-urlencoded' },\r",
					"    { key: 'Accept', value: 'application/json' }\r",
					"  ],\r",
					"  body: {\r",
					"    mode: 'urlencoded',\r",
					"    urlencoded: bodyParams\r",
					"  }\r",
					"}, function (err, res) {\r",
					"  if (err || res.code !== 200) {\r",
					"    console.error(\"Token error:\", err || res.text());\r",
					"    return;\r",
					"  }\r",
					"\r",
					"  const json = res.json();\r",
					"  pm.environment.set(\"access_token\", json.access_token);\r",
					"});\r",
					""
				]
			}
		},
