{
	"info": {
		"_postman_id": "f97e1e15-f1a9-4edb-b9f8-0620289166de",
		"name": "Automation: Vessel Controller: Time Frames",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "[AM]199417: K-IMS API: Run /api/v1/Vessels('VesselName)/TimeFrames",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "4fd6d577-f5d5-4ca8-adec-0d4dce48da44",
						"exec": [
							"let afDataSrting = pm.environment.get(\"attribute-data-values\");\r",
							"\r",
							"var afDataObject = JSON.parse(afDataSrting);\r",
							"\r",
							"const fromDate = new Date(pm.request.url.query.get('From'));\r",
							"const toDate = new Date(pm.request.url.query.get('To'));\r",
							"\r",
							"const expectedEventFrames = afDataObject.value.filter(item => {\r",
							"    const fromDateTime = new Date(item.From);\r",
							"    return fromDateTime >= fromDate && (toDate === null || fromDateTime <= toDate);\r",
							"});\r",
							"\r",
							"let response = pm.response.json().value;\r",
							"\r",
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"pm.test(\"JSON objects should be the same\", function () {\r",
							"    pm.expect(response).to.deep.equal(expectedEventFrames);\r",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"id": "66ae8d5b-aeed-4f46-a951-76d09763d47c",
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
