		{
			"name": "[AM]199417: K-IMS API: Run /api/v1/Vessels('VesselName)/TimeFrames",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "4fd6d577-f5d5-4ca8-adec-0d4dce48da44",
						"exec": [
							"let afDataObject = JSON.parse(pm.environment.get(\"attribute-data-values\"));\r",
							"let references = JSON.parse(pm.environment.get(\"references\")).references;\r",
							"\r",
							"let vesselIMO = pm.environment.get(\"vessel-IMO\");\r",
							"\r",
							"const fromDate = new Date(pm.request.url.query.get('From'));\r",
							"const toDate = new Date(pm.request.url.query.get('To'));\r",
							"\r",
							"const expectedEventFramesForPeriod = afDataObject.value.filter(item => {\r",
							"    const fromDateTime = new Date(item.From);\r",
							"    return fromDateTime >= fromDate && (toDate === null || fromDateTime <= toDate);\r",
							"});\r",
							"\r",
							"const expectedEventFramesForTheGivenVesselIMO = expectedEventFramesForPeriod.filter(item => {\r",
							"   return references.some(reference => reference[\"NameOfEventFrame\"] === item[\"Name\"] && vesselIMO === reference[\"VesselName\"]);\r",
							"});\r",
							"\r",
							"let response = pm.response.json().value;\r",
							"\r",
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"pm.test(\"JSON objects should be the same\", function () {\r",
							"    pm.expect(response).to.deep.equal(expectedEventFramesForTheGivenVesselIMO);\r",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"id": "5419d89e-0f0d-4fba-9770-9d27f28de364",
