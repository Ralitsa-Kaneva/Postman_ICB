			"item": [
				{
					"name": "456478. Run /api/v1/Vessels('{{vessel}}')/Tags('{{goodDataAttribute}}')/values?sampling-mode=raw GET request",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "f2597ffb-c9f9-4ee1-9f94-ffd1baf74641",
								"exec": [
									"let piDataSrting = pm.environment.get(\"attribute-data-values\");\r",
									"// Parse the JSON string into a JavaScript object\r",
									"var piDataObject = JSON.parse(piDataSrting);\r",
									"// Access the \"data\" array within the JSON object\r",
									"var piData = piDataObject.value;\r",
									"\r",
									"piDataLength = piData.length;\r",
									"\r",
									"let response = pm.response.json().value;\r",
									"responseLength = response.length;\r",
									"\r",
									"//Tests\r",
									"\r",
									"pm.test(\"Status code is 200\", function () \r",
									"{\r",
									"    pm.response.to.have.status(200);\r",
									"}\r",
									");\r",
									"\r",
									" pm.test(\"Body returns correct values\", function () \r",
									" {\r",
									"    isCorrectResponse = true;\r",
									"\r",
									"    if(responseLength<=10)\r",
									"    {\r",
									"        if(piDataLength > 10)\r",
									"        {\r",
									"            piData = piData.slice(0, 10);\r",
									"            items = 10;\r",
									"        }\r",
									"        else if(responseLength == piDataLength)\r",
									"        {\r",
									"            items = piDataLength;\r",
									"        }\r",
									"        else\r",
									"        {\r",
									"            isCorrectResponse = false;\r",
									"            console.log(\"The response length is different than the data length\");\r",
									"        }\r",
									"    }\r",
									"    else\r",
									"    {\r",
									"        isCorrectResponse = false;\r",
									"        console.log(\"The response length is bigger than 10 records\");\r",
									"    }\r",
									"\r",
									"    if(isCorrectResponse)\r",
									"    {\r",
									"        for(i=0; i<items; i++)\r",
									"        {\r",
									"            if(Date.parse(piData[i][\"Event Time\"]) != Date.parse(response[i].Timestamp.replace(/\\.\\d+/, \"\"))){\r",
									"                isCorrectResponse = false;\r",
									"                console.log(\"The Timestamp of the records is not correct\");\r",
									"                break;\r",
									"            }\r",
									"\r",
									"            if(piData[i].Value!=response[i].Value )\r",
									"            {\r",
									"                if(response[i].Value==null)\r",
									"                {\r",
									"                    if(!(piData[i].Substituted == true) && !(response[i].Quality == \"Bad\"))\r",
									"                    {\r",
									"                        console.log(\"The response value is null\");\r",
									"                        isCorrectResponse = false;\r",
									"                        break;\r",
									"                    }\r",
									"                    if((response[i].Quality == \"Bad\") && !(piData[i].Value == response[i].QualityInfo))\r",
									"                    {\r",
									"                        console.log(\"The response value is null but the data is good and not substituted\");\r",
									"                        isCorrectResponse = false;\r",
									"                        break;\r",
									"                    }\r",
									"                }           \r",
									"            }\r",
									"        }\r",
									"    }\r",
									"\r",
									"     pm.expect(isCorrectResponse, 'The returned values are not correct').to.be.true;\r",
									"\r",
									" });"
								],
								"type": "text/javascript"
							}
						},
