		{
			"name": "[A]199228. Run /api/v1/Vessels('VesselName')/Tags endpoint with expand parameter for restricted period",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "4c9c17dd-db1b-46ad-975a-22a3e0dc7156",
						"exec": [
							"//Define variables\r",
							"    var responseText = pm.response.text();\r",
							"    var pattern =/Timestamp\":\"2023-01-17T[0-9]{2}:[0-9]{2}:[0-9]{2}\\+02:00/\r",
							"    var pattern2 =/Timestamp\":\"2023-01-18T00:00:00\\+02:00/\r",
							"    var result = responseText.match(pattern);\r",
							"    var result2 = responseText.match(pattern2);\r",
							"    console.log(result)\r",
							"    console.log(result2)\r",
							"\r",
							"// Define a condition that you want to check (in this case, a boolean variable)\r",
							"    var isConditionTrue = (result == null && result2 == null);\r",
							"\r",
							"    if (!isConditionTrue)\r",
							"    {\r",
							"         console.log(\"Pattern 1 result is: \" + result)\r",
							"         console.log(\"Pattern 2 result is: \" + result2)\r",
							"    }\r",
							"\r",
							"//Tests\r",
							"\r",
							"    pm.test(\"Status code is 200\", function () {\r",
							"        pm.response.to.have.status(200);\r",
							"    });\r",
							"\r",
							"    pm.test(\"Check for restricted values\", function () {\r",
							"        pm.expect(isConditionTrue, 'Condition should be true').to.be.true;\r",
							"    });\r",
							""
						],
						"type": "text/javascript"
					}
				}
			],
